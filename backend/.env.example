# ==============================================================================
# 404Hire Backend Environment Configuration
# Copy this file to backend/.env and replace placeholder values.
# Never commit real secrets.
# ==============================================================================

# ------------------------------------------------------------------------------
# Server Settings
# ------------------------------------------------------------------------------
# HOST: FastAPI bind address.
# Common selections:
#   - 0.0.0.0: listen on all interfaces, recommended for Docker/Railway
#   - 127.0.0.1: local machine only
HOST=0.0.0.0

# PORT: FastAPI port.
# Common selections:
#   - 8000: local development default
#   - Railway/hosting platforms may inject their own PORT
PORT=8000

# DEBUG: enables Uvicorn reload when running backend/main.py directly.
# Selections: true, false
DEBUG=True

# SECRET_KEY: used to hash candidate passwords.
# Required for production. Use a long random value, for example:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_a_long_random_secret_key

# ------------------------------------------------------------------------------
# Supabase Persistence API
# ------------------------------------------------------------------------------
# REQUIRED DATABASE SETUP:
# 1. Create a Supabase project.
# 2. Open Supabase SQL Editor.
# 3. Run backend/supabase_schema.sql before starting the backend.
# 4. Use the backend-only service_role key below. Do not use the anon key.
#
# SUPABASE_URL: public API URL from Supabase Project Settings > API.
# Required because 404Hire uses Supabase as the only runtime persistence layer.
# Example: https://abcdefghijk.supabase.co
SUPABASE_URL=https://your-project.supabase.co

# SUPABASE_SERVICE_ROLE_KEY: backend-only service_role secret key.
# Required. Do NOT use the anon/public key. The backend performs RLS-protected
# writes to positions, candidates, applications, agent events, actions, and email receipts.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ------------------------------------------------------------------------------
# OpenAI-Compatible LLM API
# ------------------------------------------------------------------------------
# OPENAI_API_KEY: API key for OpenAI or an OpenAI-compatible provider.
# Recommended for full agentic routing and richer agent outputs. Deterministic
# fallbacks run where available if the provider is unavailable.
OPENAI_API_KEY=your_openai_or_compatible_api_key

# OPENAI_BASE_URL: base URL for the chat completions API.
# Common selections:
#   - https://api.openai.com/v1
#   - https://api.deepseek.com/v1
#   - https://api.mor.org/api/v1
#   - http://localhost:11434/v1 for a local OpenAI-compatible gateway
OPENAI_BASE_URL=https://api.openai.com/v1

# OPENAI_MODEL: default worker model for requirement, resume, matching,
# interview, report, and email-planning agents.
# Common selections depend on provider:
#   - gpt-4o-mini
#   - gpt-4o
#   - deepseek-v4-pro
#   - google/gemma-4-31B-turbo-TEE
OPENAI_MODEL=gpt-4o-mini

# OPENAI_STRUCTURED_OUTPUTS: asks compatible providers for structured JSON.
# Selections: true, false
# Keep false for providers that reject response_format/json schema requests.
OPENAI_STRUCTURED_OUTPUTS=true

# ------------------------------------------------------------------------------
# Agent Graph Orchestration
# ------------------------------------------------------------------------------
# AGENT_SUPERVISOR_MODEL: model used for the supervisor plan and email planner.
# Leave equal to OPENAI_MODEL unless your provider has a faster routing model.
AGENT_SUPERVISOR_MODEL=gpt-4o-mini

# AGENT_WORKER_MODEL: model used by worker/task agents where supported.
AGENT_WORKER_MODEL=gpt-4o-mini

# AGENT_SUPERVISOR_MODE: controls routing style.
# Selections:
#   - single_plan: one supervisor LLM plan, then execute all required tools; recommended for lower latency
#   - step_by_step: ask the supervisor for each next tool; more dynamic but slower
AGENT_SUPERVISOR_MODE=single_plan

# AGENT_MAX_STEPS: hard stop to prevent runaway graph loops.
AGENT_MAX_STEPS=10

# AGENT_DECISION_REASONS: include reason/decision_reason in streamed events.
# Selections: true, false
AGENT_DECISION_REASONS=true

# AGENT_ASYNC_GRAPH: enable async-compatible graph streaming surfaces.
# Selections: true, false
AGENT_ASYNC_GRAPH=true

# AGENT_WORKER_TIMEOUT_SECONDS: timeout per graph tool execution.
# Lower values improve responsiveness; higher values allow slower LLM providers.
AGENT_WORKER_TIMEOUT_SECONDS=20

# ------------------------------------------------------------------------------
# Bounded Autonomy And Action Policy
# ------------------------------------------------------------------------------
# AGENT_AUTONOMY_MODE: operational authority for agent actions.
# Selections:
#   - bounded: policy-checked autonomous emails/status changes; recommended
#   - manual: agent drafts and records, but requires manual approval for actions
#   - full: permits broader autonomous action after policy checks; use carefully
AGENT_AUTONOMY_MODE=bounded

# AGENT_EMAIL_REVIEW_MODE: controls candidate email behavior.
# Selections:
#   - policy: send only when action policy approves thresholds and safety
#   - manual: draft only, HR must review before sending
#   - disabled: never send agent-initiated email
AGENT_EMAIL_REVIEW_MODE=policy

# AGENT_INVITE_MIN_FIT_SCORE: minimum position-fit score for autonomous invites.
# Range: 0-100
AGENT_INVITE_MIN_FIT_SCORE=75

# AGENT_REJECT_MAX_SCREENING_SCORE: maximum screening score for autonomous rejection.
# Range: 0-100
AGENT_REJECT_MAX_SCREENING_SCORE=45

# ------------------------------------------------------------------------------
# LLM Temperature And Timeout Tuning
# ------------------------------------------------------------------------------
# LLM_TIMEOUT: request timeout in seconds for the OpenAI-compatible client.
LLM_TIMEOUT=35

# Agent temperatures.
# Range: 0.0-1.0
# Lower values are more deterministic; higher values are more creative.
RESUME_AGENT_TEMP=0.1
REQUIREMENT_AGENT_TEMP=0.2
MATCHING_AGENT_TEMP=0.4
INTERVIEW_AGENT_TEMP=0.3
REPORT_AGENT_TEMP=0.3

# ------------------------------------------------------------------------------
# SMTP Email API
# ------------------------------------------------------------------------------
# SMTP_HOST: SMTP provider host.
# Common selections:
#   - smtp.gmail.com
#   - smtp.office365.com
#   - smtp.mailgun.org
#   - smtp.sendgrid.net
SMTP_HOST=smtp.gmail.com

# SMTP_PORT: provider port.
# Selections:
#   - 587: STARTTLS/TLS, most common
#   - 465: SSL
SMTP_PORT=587

# SMTP_USER: SMTP login username, often the sending email address.
SMTP_USER=your_email@gmail.com

# SMTP_PASSWORD: SMTP password or provider app password/API password.
# For Gmail, use an app password rather than your normal account password.
SMTP_PASSWORD=your_app_specific_password

# ------------------------------------------------------------------------------
# LinkedIn Direct Scraping Integration
# ------------------------------------------------------------------------------
# LINKEDIN_LI_AT_COOKIE: authenticated LinkedIn li_at cookie.
# Optional. Use only when allowed by your account and applicable platform terms.
# Leave blank to disable direct LinkedIn scraping.
LINKEDIN_LI_AT_COOKIE=

# LINKEDIN_HEADLESS: browser visibility for direct scraping.
# Selections: true, false
LINKEDIN_HEADLESS=True

# ------------------------------------------------------------------------------
# Apify Sourcing API
# ------------------------------------------------------------------------------
# APIFY_API_TOKEN: Apify API token.
# Optional but recommended for live sourcing and profile scraping.
APIFY_API_TOKEN=

# APIFY_PROFILE_ACTOR_ID: actor used to scrape individual LinkedIn profile details.
# Common selections:
#   - curious_coder/linkedin-profile-scraper
#   - LpVuK3Zozwuipa5bp
APIFY_PROFILE_ACTOR_ID=curious_coder/linkedin-profile-scraper

# APIFY_SEARCH_ACTOR_ID: actor used to run LinkedIn people searches.
# Common selections:
#   - M2FMdjRVeF1HPGFcc
#   - curious_coder/linkedin-people-search-scraper
APIFY_SEARCH_ACTOR_ID=M2FMdjRVeF1HPGFcc

# APIFY_TIMEOUT_SECONDS: maximum wait time for Apify actor runs.
APIFY_TIMEOUT_SECONDS=90

# ------------------------------------------------------------------------------
# University Ranking Provider Readiness
# ------------------------------------------------------------------------------
# RANKING_API_URL: optional readiness URL for a future/custom ranking provider.
# Current ranking evidence uses backend/data/qs_rankings.csv, the root QS CSV,
# and Supabase institution_ranking_cache. Leave blank unless you add a custom provider.
# Example: https://your-ranking-service.com/api/rankings?institution={institution}
RANKING_API_URL=

# RANKING_API_KEY: optional bearer token for the custom ranking provider above.
# The included 2026 QS CSV does not need an API key.
RANKING_API_KEY=
